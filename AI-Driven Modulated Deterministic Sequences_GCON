import numpy as np
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches

def plot_statistical_significance():

    np.random.seed(42)  # For reproducible results

    # --- Methods + simulated data ---
    methods = [
        'Traditional Gold Codes',
        'Walsh Codes',
        'Kasami Sequences',
        'Modulated Sequences (no AI)',
        'DRL-based Power Allocation',
        'Proposed Hybrid'
    ]

    n_samples = 100
    data = {
        'Traditional Gold Codes': np.random.normal(72.1, 2.1, n_samples),
        'Walsh Codes': np.random.normal(68.3, 2.5, n_samples),
        'Kasami Sequences': np.random.normal(75.4, 1.9, n_samples),
        'Modulated Sequences (no AI)': np.random.normal(83.7, 1.6, n_samples),
        'DRL-based Power Allocation': np.random.normal(87.2, 1.4, n_samples),
        'Proposed Hybrid': np.random.normal(95.2, 1.3, n_samples)
    }

    # --- Color and hatch mapping (one-to-one with methods) ---
    colors = {
        'Traditional Gold Codes': '#1f77b4',
        'Walsh Codes': '#ff7f0e',
        'Kasami Sequences': '#2ca02c',
        'Modulated Sequences (no AI)': '#d62728',
        'DRL-based Power Allocation': '#9467bd',
        'Proposed Hybrid': '#8c564b'
    }
    hatches = ["///", "\\\\\\", "xx", "...", "oo", "**"]

    # --- Figure setup ---
    fig, ax = plt.subplots(figsize=(10, 6))

    # Create boxplot (we will draw boxes and then style them)
    box_plot = ax.boxplot(
        [data[m] for m in methods],
        labels=methods,          # temporarily set labels; we'll hide xticks later
        patch_artist=True,
        showmeans=True,
        meanline=True,
        showfliers=False,
        widths=0.6
    )

    # Style each box: color, hatch, edge
    for patch, method, hatch in zip(box_plot['boxes'], methods, hatches):
        patch.set_facecolor(colors[method])
        patch.set_edgecolor('black')
        patch.set_linewidth(0.9)
        patch.set_alpha(0.85)
        patch.set_hatch(hatch)

    # Medians
    for median in box_plot['medians']:
        median.set_color('black')
        median.set_linewidth(2)

    # Means (meanline=True draws a line; style it)
    for mean in box_plot.get('means', []):
        # mean is a Line2D; set color and linewidth
        mean.set_color('white')
        mean.set_linewidth(2)
        mean.set_markeredgecolor('red')
        mean.set_markerfacecolor('red')

    # Whiskers and caps styling for clarity
    for whisker in box_plot['whiskers']:
        whisker.set_color('black')
        whisker.set_linewidth(0.9)
    for cap in box_plot['caps']:
        cap.set_color('black')
        cap.set_linewidth(0.9)

    # Remove x-axis labels (methods will be shown in the legend)
    ax.set_xticks([])
    ax.set_xlabel("Methods",fontsize=14,fontweight='bold')

    # Y-axis label and limits (keep real scale)
    ax.set_ylabel('Handover Success Rate (%)', fontsize=14, fontweight='bold')
    ax.set_ylim(60, 102)
    ax.grid(True, axis='y', linestyle='--', alpha=0.25)
    ax.set_axisbelow(True)

    # --- Build a legend INSIDE the plot (upper-left) with hatch + color samples ---
    legend_handles = []
    for method, hatch in zip(methods, hatches):
        # create a patch with same facecolor, edgecolor and hatch
        p = mpatches.Patch(facecolor=colors[method],
                           edgecolor='black',
                           hatch=hatch,
                           label=method,
                           alpha=0.85)
        legend_handles.append(p)

    ax.legend(handles=legend_handles,
              frameon=False,
              loc='upper left',
              bbox_to_anchor=(0.02, 0.90))

    # --- ANOVA annotation (moved below legend to avoid overlap) ---
    ax.text(
        0.02, 0.92,   # lowered so it does not overlap the legend
        'ANOVA Results:\nF(5,594) = 312.7, p < 0.001',
        transform=ax.transAxes,
        fontsize=12,
        fontweight='bold',
        bbox=dict(boxstyle="round,pad=0.3", facecolor="lightgray", alpha=0.8)
    )

    # Rotate x labels (hidden) and finalize
    plt.tight_layout()
    plt.savefig('statistical_significance_boxplot.pdf', dpi=300, bbox_inches='tight')
    plt.show()

    return fig

