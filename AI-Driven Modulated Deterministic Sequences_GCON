def plot_handover_success_rate():
    """Plot IEEE-style handover success rate comparison with colors + hatching + inside legend."""

    # Methods + Data
    methods = [
        'Traditional Gold Codes',
        'Walsh Codes',
        'Kasami Sequences',
        'Modulated Sequences (no AI)',
        'DRL-based Power Allocation',
        'Proposed Hybrid'
    ]

    success_rates = [72.1, 68.3, 75.4, 83.7, 87.2, 95.2]
    confidence_intervals = [2.1, 2.5, 1.9, 1.6, 1.4, 1.3]

    # Colors (same order as methods)
    colors = [
        '#1f77b4',  # blue
        '#ff7f0e',  # orange
        '#2ca02c',  # green
        '#d62728',  # red
        '#9467bd',  # purple
        '#8c564b',  # brown
    ]

    # IEEE hatch patterns
    hatches = ["///", "\\\\", "xx", "...", "oo", "**"]

    fig, ax = plt.subplots(figsize=(10, 6))

    x = np.arange(len(methods))
    width = 0.55

    bars = []
    for i, method in enumerate(methods):
        bar = ax.bar(
            x[i],
            success_rates[i],
            width,
            yerr=confidence_intervals[i],
            capsize=5,
            color=colors[i],                     # <-- COLOR restored
            edgecolor="black",
            hatch=hatches[i],                   # <-- HATCH pattern added
            label=method,
            alpha=0.9,
            linewidth=1
        )
        bars.append(bar)

    # Value labels
    for i, rate in enumerate(success_rates):
        ax.text(
            x[i],
            rate + 2.4,
            f"{rate}%",
            ha="center", va="bottom",
            fontsize=12, fontweight="bold"
        )

    # Remove x-axis labels (legend shows methods)
    ax.set_xticks([])
    ax.set_xlabel("Methods", fontsize=14, fontweight='bold')

    # Y-axis formatting
    ax.set_ylabel("Handover Success Rate (%)", fontsize=14, fontweight='bold')
