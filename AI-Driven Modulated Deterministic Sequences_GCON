def plot_radar_chart():
    """Plot comprehensive performance comparison using radar chart"""

    categories = ['HSR (%)', 'Throughput\n(Mbps)', 'Interference\nReduction (%)',
                  'Energy\nEfficiency', 'QoS\nSatisfaction (%)', 'Latency\n(ms)']

    # Normalized performance scores (0-100 scale)
    proposed_scores = [95, 85, 90, 88, 92, 82]  # Higher is better for all metrics
    baseline_scores = [72, 65, 40, 60, 70, 60]   # Average baseline performance

    # Number of categories
    N = len(categories)

    # Compute angles for radar chart
    angles = [n / float(N) * 2 * np.pi for n in range(N)]
    angles += angles[:1]  # Complete the circle

    # Complete the scores for radar chart
    proposed_scores += proposed_scores[:1]
    baseline_scores += baseline_scores[:1]
    categories += categories[:1]

    fig, ax = plt.subplots(figsize=(10, 10), subplot_kw=dict(projection='polar'))

    # Plot proposed method
    ax.plot(angles, proposed_scores, 'o-', linewidth=2,
            label='Proposed Hybrid', color=colors['Proposed Hybrid'])
    ax.fill(angles, proposed_scores, alpha=0.25, color=colors['Proposed Hybrid'])

    # Plot baseline
    ax.plot(angles, baseline_scores, 'o-', linewidth=2,
            label='Average Baseline', color='gray', alpha=0.7)
    ax.fill(angles, baseline_scores, alpha=0.1, color='gray')

    # Add category labels
    ax.set_xticks(angles[:-1])
    ax.set_xticklabels(categories[:-1], fontsize=10)

    # Set y-axis limits and labels
    ax.set_ylim(0, 100)
    ax.set_yticks([20, 40, 60, 80, 100])
    ax.set_yticklabels(['20', '40', '60', '80', '100'], fontsize=9)
    ax.grid(True)

    ax.set_title('Comprehensive Performance Radar Chart\n(Higher is Better for All Metrics)',
                 fontsize=12, fontweight='bold', pad=20)
    ax.legend(loc='upper right', bbox_to_anchor=(1.3, 1.0))

    plt.tight_layout()
    plt.savefig('radar_chart.pdf', dpi=300, bbox_inches='tight')
    plt.show()

    return fig

