      transform=ax.transAxes,
      fontsize=12,
      fontweight="bold",
      bbox=dict(boxstyle="round,pad=0.3", facecolor="lightgray", alpha=0.5)
)

    plt.tight_layout()
    plt.savefig("handover_success_rate.pdf", dpi=300, bbox_inches="tight")
    plt.show()

    return fig

