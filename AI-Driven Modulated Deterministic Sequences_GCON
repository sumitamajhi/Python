def plot_convergence_analysis():
    """Plot DQN learning convergence curve"""

    episodes = np.arange(0, 8000, 100)

    # Simulate convergence behavior with three phases
    exploration_phase = 1500
    learning_phase = 4000

    # Create realistic convergence curve
    reward = np.zeros_like(episodes, dtype=float)

    for i, ep in enumerate(episodes):
        if ep <= exploration_phase:
            # Exploration phase: high variance, slow improvement
            reward[i] = 10 + 20 * (ep/exploration_phase) + np.random.normal(0, 8)
        elif ep <= learning_phase:
            # Learning phase: steady improvement
            progress = (ep - exploration_phase) / (learning_phase - exploration_phase)
            reward[i] = 30 + 40 * progress + np.random.normal(0, 4)
        else:
            # Convergence phase: stable with minimal fluctuations
            reward[i] = 70 + 10 * (1 - np.exp(-(ep - learning_phase)/1000)) + np.random.normal(0, 2)

    fig, ax = plt.subplots(figsize=(10, 6))

    # Plot convergence curve
    ax.plot(episodes, reward, linewidth=2, color=colors['Proposed Hybrid'], alpha=0.8)

    # Add phase annotations
    ax.axvline(x=exploration_phase, color='red', linestyle='--', alpha=0.7, linewidth=1)
    ax.axvline(x=learning_phase, color='green', linestyle='--', alpha=0.7, linewidth=1)

    ax.text(exploration_phase/2, 15, 'Exploration\nPhase',
            ha='center', va='center', fontsize=10, fontweight='bold',
            bbox=dict(boxstyle="round,pad=0.3", facecolor="lightcoral", alpha=0.7))
    ax.text((exploration_phase + learning_phase)/2, 45, 'Learning\nPhase',
            ha='center', va='center', fontsize=10, fontweight='bold',
            bbox=dict(boxstyle="round,pad=0.3", facecolor="lightgreen", alpha=0.7))
    ax.text((learning_phase + 8000)/2, 75, 'Convergence\nPhase',
            ha='center', va='center', fontsize=10, fontweight='bold',
            bbox=dict(boxstyle="round,pad=0.3", facecolor="lightblue", alpha=0.7))

    ax.set_xlabel('Training Episodes', fontsize=15, fontweight='bold')
    ax.set_ylabel('Average Reward', fontsize=15, fontweight='bold')
    #ax.set_title('DQN Learning Convergence Analysis', fontsize=12, fontweight='bold', pad=20)
    ax.grid(True, alpha=0.3)
    ax.set_ylim(0, 85)

    # Add convergence point annotation
    ax.annotate(f'Convergence: {learning_phase} episodes',
                xy=(learning_phase, 70), xytext=(5000, 50),
                arrowprops=dict(arrowstyle='->', color='blue', lw=0.5),
                fontsize=12, fontweight='bold')

    plt.tight_layout()
    plt.savefig('convergence_analysis.pdf', dpi=300, bbox_inches='tight')
    plt.show()

    return fig

