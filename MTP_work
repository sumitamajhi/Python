def run_comprehensive_evaluation():
    """Run comprehensive evaluation across all scenarios"""
    scenarios = ['smart_city', 'industrial', 'sensor_network']
    algorithms = ['static', 'npg', 'ddpg']

    all_results = []

    for scenario in scenarios:
        print(f"\n=== Evaluating {scenario.replace('_', ' ').title()} Scenario ===")

        # Create simulator and evaluator
        simulator = IoTNetworkSimulator(scenario)
        evaluator = RLAlgorithmEvaluator(simulator)

        # Run simulations for each algorithm
        for algorithm in algorithms:
            print(f"Running {algorithm.upper()} algorithm...")

            if algorithm == 'static':
                results = evaluator.simulate_static_allocation()
            elif algorithm == 'npg':
                results = evaluator.simulate_npg_allocation()
            elif algorithm == 'ddpg':
                results = evaluator.simulate_ddpg_allocation()

            all_results.append(results)

    return pd.DataFrame(all_results)

