class IoTNetworkSimulator:
    """Simulator for IoT network performance evaluation"""

    def __init__(self, scenario_type='smart_city'):
        self.scenario_type = scenario_type
        self.set_scenario_parameters()

    def set_scenario_parameters(self):
        """Set parameters based on IoT deployment scenario"""
        if self.scenario_type == 'smart_city':
            self.num_devices = 120
            self.cell_radius = 1000  # meters
            self.device_classes = {
                'critical': 0.3,    # 30% critical devices
                'periodic': 0.4,    # 40% periodic devices
                'best_effort': 0.3  # 30% best-effort devices
            }
            self.reliability_targets = {
                'critical': 0.999,
                'periodic': 0.95,
                'best_effort': 0.90
            }

        elif self.scenario_type == 'industrial':
            self.num_devices = 65
            self.cell_radius = 500  # meters
            self.device_classes = {
                'critical': 0.4,    # 40% critical devices
                'periodic': 0.4,    # 40% periodic devices
                'best_effort': 0.2  # 20% best-effort devices
            }
            self.reliability_targets = {
                'critical': 0.9999,
                'periodic': 0.995,
                'best_effort': 0.95
            }

        elif self.scenario_type == 'sensor_network':
            self.num_devices = 250
            self.cell_radius = 5000  # meters
            self.device_classes = {
                'critical': 0.2,    # 20% critical devices
                'periodic': 0.5,    # 50% periodic devices
                'best_effort': 0.3  # 30% best-effort devices
            }
            self.reliability_targets = {
                'critical': 0.99,
                'periodic': 0.90,
                'best_effort': 0.85
            }

        # Initialize devices
        self.initialize_devices()

    def initialize_devices(self):
        """Initialize IoT devices with random parameters"""
        self.devices = []
        class_distribution = []

        # Create device class distribution
        for class_type, proportion in self.device_classes.items():
            count = int(self.num_devices * proportion)
            class_distribution.extend([class_type] * count)

        # Adjust for rounding
        while len(class_distribution) < self.num_devices:
            class_distribution.append('best_effort')

        np.random.shuffle(class_distribution)

        for i in range(self.num_devices):
            device = {
                'id': i,
                'class': class_distribution[i],
                'distance': np.random.uniform(50, self.cell_radius),
                'power_max': np.random.uniform(10, 23),  # dBm
                'battery_energy': np.random.uniform(0.3, 1.0),  # normalized
                'reliability_req': self.reliability_targets[class_distribution[i]],
                'latency_tolerance': np.random.uniform(1, 1000),  # ms
                'activity_factor': np.random.uniform(0.3, 0.8)
            }
            self.devices.append(device)

    def calculate_channel_gain(self, device):
        """Calculate channel gain for a device"""
        # Simplified path loss model
        d = device['distance']
        if self.scenario_type == 'industrial':
            # Indoor path loss
            path_loss_db = 35.3 + 22 * np.log10(2.4) + 21.3 * np.log10(d/1000)
        else:
            # Outdoor path loss
            path_loss_db = 32.4 + 20 * np.log10(2.4) + 20 * np.log10(d/1000)

        path_loss_linear = 10**(-path_loss_db/10)
        # Small-scale fading (Rayleigh)
        small_scale_fading = np.random.rayleigh(1)

        return path_loss_linear * small_scale_fading * device['activity_factor']

    def generate_gold_codes(self, num_codes, code_length=63):
        """Generate simulated Gold code cross-correlation matrix"""
        # Create a realistic cross-correlation matrix for Gold codes
        np.random.seed(42)
        base_correlation = 0.1  # Base cross-correlation for Gold codes

        # Generate correlation matrix with Gold code properties
        correlation_matrix = np.eye(num_codes)
        for i in range(num_codes):
            for j in range(i+1, num_codes):
                # Gold codes have bounded cross-correlation
                corr = base_correlation + np.random.uniform(-0.05, 0.05)
                correlation_matrix[i, j] = corr
                correlation_matrix[j, i] = corr

        return correlation_matrix

# %%
class RLAlgorithmEvaluator:
    """Evaluate RL algorithm performance"""

    def __init__(self, simulator):
        self.simulator = simulator
        self.results = {}

    def simulate_static_allocation(self):
        """Simulate traditional static code allocation"""
        num_codes = int(self.simulator.num_devices * 0.8)  # 80% code pool size
        correlation_matrix = self.simulator.generate_gold_codes(num_codes)

        # Static assignment: devices randomly assigned to codes
        code_assignments = np.random.randint(0, num_codes, self.simulator.num_devices)

        return self.calculate_performance_metrics(code_assignments, correlation_matrix, 'static')

    def simulate_npg_allocation(self):
        """Simulate NPG-based dynamic allocation"""
        # Simulate NPG performance with intelligent assignment
        num_codes = int(self.simulator.num_devices * 0.8)
        correlation_matrix = self.simulator.generate_gold_codes(num_codes)

        # NPG: intelligent assignment considering device classes
        code_assignments = self.intelligent_assignment('npg', correlation_matrix)

        return self.calculate_performance_metrics(code_assignments, correlation_matrix, 'npg')

    def simulate_ddpg_allocation(self):
        """Simulate DDPG-based dynamic allocation"""
        num_codes = int(self.simulator.num_devices * 0.8)
        correlation_matrix = self.simulator.generate_gold_codes(num_codes)

        # DDPG: continuous embedding-based assignment
        code_assignments = self.intelligent_assignment('ddpg', correlation_matrix)

        return self.calculate_performance_metrics(code_assignments, correlation_matrix, 'ddpg')

    def intelligent_assignment(self, algorithm_type, correlation_matrix):
        """Perform intelligent code assignment based on algorithm type"""
        num_codes = correlation_matrix.shape[0]
        assignments = np.zeros(self.simulator.num_devices, dtype=int)

        # Priority-based assignment for critical devices
        critical_indices = [i for i, d in enumerate(self.simulator.devices)
                          if d['class'] == 'critical']
        periodic_indices = [i for i, d in enumerate(self.simulator.devices)
                          if d['class'] == 'periodic']
        best_effort_indices = [i for i, d in enumerate(self.simulator.devices)
                             if d['class'] == 'best_effort']

        # Assign codes with minimum correlation to critical devices
        available_codes = set(range(num_codes))

        # Critical devices get codes with lowest average correlation
        if algorithm_type == 'npg':
            # NPG: stable assignment with good correlation properties
            for idx in critical_indices:
                if available_codes:
                    best_code = min(available_codes,
                                  key=lambda c: np.mean([correlation_matrix[c, assignments[j]]
                                                       for j in range(idx) if j in critical_indices]
                                                       if idx > 0 else [0]))
                    assignments[idx] = best_code
                    available_codes.remove(best_code)

        elif algorithm_type == 'ddpg':
            # DDPG: more adaptive assignment considering multiple factors
            for idx in critical_indices:
                if available_codes:
                    # Consider both correlation and channel conditions
                    channel_gain = self.simulator.calculate_channel_gain(self.simulator.devices[idx])
                    best_code = min(available_codes,
                                  key=lambda c: (np.mean([correlation_matrix[c, assignments[j]]
                                                        for j in range(idx) if assignments[j] != -1]
                                                        if idx > 0 else [0]) *
                                               (1 + 0.5/channel_gain)))
                    assignments[idx] = best_code
                    available_codes.remove(best_code)

        # Remaining devices get random assignment from available codes
        remaining_indices = periodic_indices + best_effort_indices
        for idx in remaining_indices:
            if available_codes:
                assignments[idx] = np.random.choice(list(available_codes))
                available_codes.remove(assignments[idx])
            else:
                # Reuse codes if necessary (with potential interference)
                assignments[idx] = np.random.randint(0, num_codes)

        return assignments

    def calculate_performance_metrics(self, assignments, correlation_matrix, algorithm):
        """Calculate comprehensive performance metrics"""
        metrics = {
            'algorithm': algorithm,
            'scenario': self.simulator.scenario_type,
            'throughput': 0,
            'energy_efficiency': 0,
            'reliability': {},
            'fairness': 0,
            'interference': 0
        }

        # Calculate SINR and throughput for each device
        throughputs = []
        energies = []
        reliabilities = {class_type: [] for class_type in ['critical', 'periodic', 'best_effort']}

        for i, device in enumerate(self.simulator.devices):
            # Calculate received power
            channel_gain = self.simulator.calculate_channel_gain(device)
            power_dbm = device['power_max']
            power_linear = 10**((power_dbm - 30)/10)  # Convert to Watts

            # Calculate interference
            interference = 0
            for j, other_device in enumerate(self.simulator.devices):
                if i != j:
                    other_channel_gain = self.simulator.calculate_channel_gain(other_device)
                    other_power_dbm = other_device['power_max']
                    other_power_linear = 10**((other_power_dbm - 30)/10)
                    corr = correlation_matrix[assignments[i], assignments[j]]
                    interference += corr * other_power_linear * other_channel_gain

            # Calculate SINR
            noise_power = 10**((-174 - 30)/10)  # -174 dBm/Hz thermal noise
            sinr = (power_linear * channel_gain) / (noise_power + interference)

            # Calculate throughput (simplified Shannon capacity)
            throughput = np.log2(1 + sinr)
            throughputs.append(throughput)

            # Calculate energy efficiency
            energy_eff = throughput / (power_linear * 1e3)  # bits/Joule
            energies.append(energy_eff)

            # Check reliability
            required_sinr = -np.log(1 - device['reliability_req'])  # Map reliability to SINR requirement
            is_reliable = 1 if sinr >= required_sinr else 0
            reliabilities[device['class']].append(is_reliable)

        # Aggregate metrics
        metrics['throughput'] = np.sum(throughputs)
        metrics['energy_efficiency'] = np.mean(energies)
        metrics['fairness'] = self.jains_fairness_index(throughputs)
        metrics['interference'] = np.mean([correlation_matrix[assignments[i], assignments[j]]
                                        for i in range(len(assignments))
                                        for j in range(i+1, len(assignments))])

        # Calculate reliability per class
        for class_type in reliabilities:
            if reliabilities[class_type]:
                metrics['reliability'][class_type] = np.mean(reliabilities[class_type])
            else:
                metrics['reliability'][class_type] = 0

        return metrics

    def jains_fairness_index(self, values):
        """Calculate Jain's fairness index"""
        if np.sum(values) == 0:
            return 0
        return (np.sum(values)**2) / (len(values) * np.sum(np.array(values)**2))

