def create_figure5():
    """Create robustness analysis under impairments"""

    # Impairment levels
    phase_noise_levels = np.array([-40, -35, -30, -25])  # dBc
    iq_imbalance_levels = np.array([35, 30, 25, 20])  # IRR in dB
    csi_error_levels = np.array([0.0, 0.1, 0.2, 0.3])  # Normalized error

    # Performance degradation under impairments
    rs_noma_phase = [100, 97, 92, 85]  # % performance
    conventional_noma_phase = [100, 94, 86, 75]
    wmmse_phase = [100, 91, 80, 65]

    rs_noma_iq = [100, 95, 88, 80]
    conventional_noma_iq = [100, 92, 82, 70]
    wmmse_iq = [100, 89, 76, 60]

    rs_noma_csi = [100, 96, 89, 79]
    conventional_noma_csi = [100, 90, 77, 62]
    wmmse_csi = [100, 87, 71, 53]

    fig, (ax1, ax2, ax3) = plt.subplots(1, 3, figsize=(20, 6))

    # Plot 1: Phase Noise Robustness
    ax1.plot(phase_noise_levels, rs_noma_phase, 'o-', linewidth=3,
             label='RS-NOMA', color='#2E86AB', markersize=8)
    ax1.plot(phase_noise_levels, conventional_noma_phase, 's-', linewidth=3,
             label='Conventional NOMA', color='#A23B72', markersize=8)
    ax1.plot(phase_noise_levels, wmmse_phase, '^-', linewidth=3,
             label='Enhanced WMMSE', color='#F18F01', markersize=8)
    ax1.set_xlabel('Phase Noise (dBc)', fontsize=14)
    ax1.set_ylabel('Relative Performance (%)', fontsize=14)
    ax1.set_title('Robustness to Phase Noise', fontweight='bold', pad=15)
    ax1.legend(framealpha=0.9)
    ax1.grid(True, alpha=0.3)
    ax1.invert_xaxis()  # Worse impairment to the right

    # Add performance labels at key points
    for i, (x, y) in enumerate(zip(phase_noise_levels, rs_noma_phase)):
        if i in [1, 2]:  # Only label key points to avoid clutter
            ax1.annotate(f'{y}%', xy=(x, y), xytext=(5, 5), textcoords='offset points',
                        fontweight='bold', fontsize=10,
                        bbox=dict(boxstyle="round,pad=0.2", facecolor="white", alpha=0.7))

    # Plot 2: I/Q Imbalance Robustness
    ax2.plot(iq_imbalance_levels, rs_noma_iq, 'o-', linewidth=3,
             label='RS-NOMA', color='#2E86AB', markersize=8)
    ax2.plot(iq_imbalance_levels, conventional_noma_iq, 's-', linewidth=3,
             label='Conventional NOMA', color='#A23B72', markersize=8)
    ax2.plot(iq_imbalance_levels, wmmse_iq, '^-', linewidth=3,
             label='Enhanced WMMSE', color='#F18F01', markersize=8)
    ax2.set_xlabel('I/Q Imbalance (IRR, dB)', fontsize=14)
    ax2.set_ylabel('Relative Performance (%)', fontsize=14)
    ax2.set_title('Robustness to I/Q Imbalance', fontweight='bold', pad=15)
    ax2.legend(framealpha=0.9)
    ax2.grid(True, alpha=0.3)
    ax2.invert_xaxis()

    # Plot 3: CSI Imperfection Robustness
    ax3.plot(csi_error_levels, rs_noma_csi, 'o-', linewidth=3,
             label='RS-NOMA', color='#2E86AB', markersize=8)
    ax3.plot(csi_error_levels, conventional_noma_csi, 's-', linewidth=3,
             label='Conventional NOMA', color='#A23B72', markersize=8)
    ax3.plot(csi_error_levels, wmmse_csi, '^-', linewidth=3,
             label='Enhanced WMMSE', color='#F18F01', markersize=8)
    ax3.set_xlabel('CSI Error (Normalized)', fontsize=14)
    ax3.set_ylabel('Relative Performance (%)', fontsize=14)
    ax3.set_title('Robustness to Imperfect CSI', fontweight='bold', pad=15)
    ax3.legend(framealpha=0.9)
    ax3.grid(True, alpha=0.3)

    plt.tight_layout(pad=3.0)
    plt.savefig('figure5_robustness_analysis.png', dpi=300, bbox_inches='tight')
    plt.show()

